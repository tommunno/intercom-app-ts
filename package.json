{
  "name": "intercom-app-ts",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server/main.js",
  "bin": "dist/server/main.js",
  "scripts": {
    "clean": "rimraf dist public/dist",
    "build:audio-engine": "cd audio-engine && npm run build",
    "build:client": "webpack",
    "build:server": "tsc -p src/server/tsconfig.server.json",
    "build": "npm run clean && npm run build:audio-engine && npm run build:client && npm run build:server",
    "build-": "npm run clean && npm run build:client && npm run build:server",
    "watch:server-tsc": "tsc -p src/server/tsconfig.server.json --watch",
    "watch:client": "npx webpack --watch --mode development",
    "watch:server-node": "node --watch dist/server/main.js",
    "watch": "concurrently -n \"TS-S, WP-C, APP\" -c \"blue,green,magenta\" \"npm run watch:server-tsc\" \"npm run watch:client\" \"npm run watch:server-node\"",
    "start": "node dist/server/main.js"
  },
  "workspaces": [
    "audio-engine"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tommunno/intercom-app-ts.git"
  },
  "keywords": [],
  "author": "Tom Munno",
  "license": "UNLICENSED",
  "type": "module",
  "bugs": {
    "url": "https://github.com/tommunno/intercom-app-ts/issues"
  },
  "homepage": "https://github.com/tommunno/intercom-app-ts#readme",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.5",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "rimraf": "^6.1.2",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "tiny-typed-emitter": "^2.1.0",
    "ws": "^8.19.0"
  }
}
